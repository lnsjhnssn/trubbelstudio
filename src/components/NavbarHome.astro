---
interface Props {
  title?: string;
}

const { title = "trubbelstudio" } = Astro.props;
---

<nav class="navbar">
  <div class="navbar-container">
    <!-- <div>
      <a href="/" class="navbar-link">←back</a>
    </div> -->

    <div class="navbar-menu">
      <a href="/about" class="navbar-link">about</a>
      <!-- <a href="/" class="navbar-link">projects</a> -->
    </div>
  </div>
</nav>

<style>
  .navbar {
    width: 100%;
  }

  .navbar-container {
    display: flex;
    justify-content: end;
    align-items: center;
    margin: var(--space-l) 0;
  }

  .navbar-brand {
    font-size: var(--step-0);
    display: none;
    text-decoration: none;
    /* font-weight: var(--font-weight-bold); */
    /* background-color: var(--lynn-bg);
    padding: 0.2rem 0.5rem; */
    /* border-radius: var(--space-xs); */
    color: var(--gray-2);
  }

  .navbar-brand:hover {
    color: var(--apple-bg);
  }

  .navbar-menu {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .navbar-link {
    font-size: var(--step-0);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .navbar-link:hover {
    text-decoration: underline;
  }
</style>
