---
import SocialLinks from "./SocialLinks.astro";
import Menu from "./Menu.astro";
interface Props {
  title?: string;
}

const { title = "trubbelstudio" } = Astro.props;

// Get current path for active link styling
const currentPath = Astro.url.pathname;

// Function to check if a link should be active
const isActive = (path: string) => {
  // For home page
  if (path === "/" && (currentPath === "/" || currentPath === "")) return true;
  // For about page
  if (path === "/about" && currentPath.startsWith("/about")) return true;
  // For work pages - also active on homepage
  if (
    path === "/work/all" &&
    (currentPath.startsWith("/work/") || currentPath === "/")
  )
    return true;
  return false;
};
---

<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-menu">
      <ul class="menu">
        <li>Linus Riihimäki</li>
        <li>
          <a href="/about" class={isActive("/about") ? "active" : ""}>About</a>
        </li>
        <li>
          <a href="/work/all" class={isActive("/work/all") ? "active" : ""}
            >Work</a
          >
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .navbar {
    width: 100%;
  }
  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: var(--space-xl) 0 var(--space-3xl) 0;
    line-height: 1;
  }

  .navbar-menu {
    display: flex;
    justify-content: end;
    line-height: 1;
  }

  .navbar-logo {
    display: flex;
    justify-content: start;
    line-height: 1;
  }

  .menu {
    display: flex;
    flex-direction: row;
    gap: var(--space-m);
    justify-content: end;
    align-items: start;
  }

  .menu a {
    text-decoration: none;
    color: light-dark(var(--text-color), var(--text-color-dark));
  }

  .menu a.active {
    font-weight: bold;
    color: var(--obsidian-accent);
  }

  .display-none {
    display: none;
  }

  .navbar-logo h1 {
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 1;
    border-radius: 9999px;
  }

  .navbar-logo h1 {
    text-decoration: none;
    color: light-dark(var(--text-color), var(--text-color-dark));
  }

  @media (hover: hover) {
    .navbar-logo a:hover {
      color: var(--text-color);
    }
  }
</style>
