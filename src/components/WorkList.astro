---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

interface Props {
  tag?: string;
}

const { tag } = Astro.props;
const allWorkPosts = await getCollection("work");
const publishedPosts = allWorkPosts.filter(
  (post) => post.data.published !== false,
);
const filteredPosts = tag
  ? publishedPosts.filter((post) => post.data.tags?.includes(tag))
  : publishedPosts;
const sortedPosts = filteredPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Get current path for active link styling
const currentPath = Astro.url.pathname;

// Function to check if a link should be active
const isActive = (path: string) => {
  if (path === "/work/web" && currentPath.startsWith("/work/web")) return true;
  if (path === "/work/sound" && currentPath.startsWith("/work/sound"))
    return true;
  if (
    path === "/work/all" &&
    (currentPath.startsWith("/work/all") || currentPath === "/")
  )
    return true;
  return false;
};
---

<div class="work-header">
  <h1>Hello!</h1>

  <div class="work-header-links">
    <a href="/work/web" class={isActive("/work/web") ? "active" : ""}>Web</a>
    <span class="separator">|</span>
    <a href="/work/sound" class={isActive("/work/sound") ? "active" : ""}
      >Sound & Music</a
    >
    <span class="separator">|</span>
    <a href="/work/all" class={isActive("/work/all") ? "active" : ""}>All</a>
  </div>
</div>

<ul class="work-list">
  {
    sortedPosts.map((post) => (
      <li>
        <div class="card">
          <div>
            <a href={`/work/${post.slug}`} class="image-link" data-tag={tag}>
              {post.data.cover && (
                <Image
                  class="image"
                  src={post.data.cover}
                  alt={post.data.coverAlt || post.data.title}
                  transition:name={`work-image-${post.slug}`}
                />
              )}
            </a>
          </div>

          <div class="text-content">
            <a href={`/work/${post.slug}`} class="text-link" data-tag={tag}>
              <h2>{post.data.title}</h2>
            </a>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="tags">
                {post.data.tags.map((postTag: string) => (
                  <span class="tag" data-tag={postTag}>
                    {postTag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      </li>
    ))
  }
</ul>

<script>
  // Store the current filter in history state
  document.addEventListener("DOMContentLoaded", () => {
    const currentPath = window.location.pathname;
    const filter = currentPath.split("/").pop();

    // Store the filter in history state
    window.history.replaceState({ filter }, "", currentPath);

    // Handle clicks on work items
    const links = document.querySelectorAll<HTMLAnchorElement>(".image-link");
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        const tag = link.getAttribute("data-tag");
        if (tag) {
          window.history.pushState({ filter: tag }, "", link.href);
        }
      });
    });
  });
</script>

<style>
  h2 {
    font-size: var(--step-0);
    font-weight: 500;
    letter-spacing: -0.06em;
  }

  .subtitle {
    font-size: var(--step--1);
  }

  .work-list {
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: var(--space-xl);
    list-style: none;
    padding: 0;
  }

  .work-header {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: start;
  }

  .work-header-links {
    display: flex;
    gap: var(--space-s);
    margin-top: var(--space-m);
    margin-bottom: var(--space-l);
    font-size: var(--step-0);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    width: 100%;
  }

  @media screen and (max-width: 760px) {
    .work-header-links {
      flex-direction: column;
      gap: var(--space-s);
    }

    .separator {
      display: none;
    }
  }

  .image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    margin-top: var(--space-2xs);
    border-radius: var(--radius-xs);
  }

  .image:hover {
    border: 5px solid var(--apple-bg);
  }

  .date {
    margin-bottom: var(--space-3xs) 0;
    color: var(--mist-text);
    font-size: var(--step--1);
  }

  .work-header-links a {
    text-decoration: none;
    color: light-dark(var(--text-color-dark), var(--text-color-dark));
  }

  .filter-text {
    color: light-dark(var(--text-secondary), var(--text-secondary-dark));
  }

  .work-header-links a.active {
    font-weight: bold;
    color: var(--obsidian-accent);
  }

  .subtitle {
    color: light-dark(var(--text-secondary), var(--text-secondary-dark));
    margin-top: var(--space-2xs);
    font-size: var(--step--1);
  }

  .text-link {
    text-decoration: none;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin-top: var(--space-2xs);
  }

  .tag {
    display: inline-block;
    padding: 0.125rem var(--space-2xs);
    border-radius: 999px;
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: capitalize;
    transition: all 0.2s ease-in-out;
    border: none;
    color: inherit;
    background-color: light-dark(#e2e4e9, rgb(36, 36, 36));
  }

  @media (hover: hover) {
    .text-link:hover {
      text-decoration: none;
      font-weight: var(--font-weight-normal);
      /* color: var(--obsidian-accent); */
      transition: 0.5s ease-in-out;
    }
  }
</style>
