---
import SocialLinks from "../components/SocialLinks.astro";
---

<div class="header">
  <h1>Hejsan, my name is Linus.</h1>
  <p class="subtitle">
    I'm a Web Developer and Sound Designer from Norrbotten, Sweden. Living in
    Geneva, Switzerland.
  </p>
  <p>
    Get in touch:
    <a href="mailto:lnsjhnssn@gmail.com" class="mail-link">
      lnsjhnssn@gmail.com
    </a>
  </p>
  <div class="social-links">
    <SocialLinks />
  </div>
</div>

<style>
  .header {
    max-width: 570px;
    margin-bottom: var(--space-xl);
    margin-top: var(--space-3xl);
  }

  .social-links {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }
  .subtitle {
    max-width: 520px;
  }

  /* @media screen and (min-width: 689px) {
    main {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  } */

  h1 {
    font-size: var(--step-0);
    line-height: 1.5;
    margin-bottom: 1em;
    font-weight: var(--font-weight-normal);
  }
</style>
