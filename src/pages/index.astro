---
import Layout from "../layouts/Layout.astro";
import NavbarHome from "../components/NavbarHome.astro";
import { SITE_TITLE, SITE_DESCRIPTION_FR } from "../consts";
import Blog from "../components/Blog.astro";

import Bluesky from "../assets/images/bluesky.svg";
import GitHub from "../assets/images/github.svg";
import LinkedIn from "../assets/images/linkedin.com.svg";
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION_FR}>
  <NavbarHome />
  <main>
    <div class="subtitle">
      <h1>Hejsan, I'm Linus.</h1>
      <p>
        Web Developer & Sound Designer from Norrbotten, Sweden.
        <br />
        Living in Geneva, Switzerland.
      </p>
      <p>
        I am available for work. Get in touch:
        <a href="mailto:lnsjhnssn@gmail.com" class="mail-link">
          lnsjhnssn@gmail.com
        </a>
      </p>
      <div class="social-links">
        <p>
          <a href="https://github.com/lnsjhnssn" class="out-link">
            <GitHub width={22} height={22} fill="currentColor" />
          </a>
        </p>
        <p>
          <a
            href="https://bsky.app/profile/linusjohansson.bsky.social"
            class="out-link"
          >
            <Bluesky width={22} height={22} fill="currentColor" />
          </a>
        </p>
        <p>
          <a
            href="https://www.linkedin.com/in/linus-johansson-8000000000/"
            class="out-link"
          >
            <LinkedIn width={22} height={22} fill="currentColor" />
          </a>
        </p>
      </div>
    </div>

    <section>
      <Blog />
    </section>
  </main>
</Layout>

<style>
  .subtitle {
    max-width: 570px;
    margin-bottom: var(--space-xl);
  }

  .social-links {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-l);
  }

  @media screen and (min-width: 689px) {
    main {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  h1 {
    font-size: var(--step-0);
    font-weight: var(--font-weight-normal);
    line-height: 1.5;
    margin-bottom: 1em;
  }
</style>
