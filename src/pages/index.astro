---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION_FR } from "../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION_FR} />
  </head>
  <body>
    <Header />
    <main>
      <p class="subtitle">
        Web dev, son & musique. <br />
        <a href="mailto:lnsjhnssn@gmail.com" class="mail-link"
          >lnsjhnssn@gmail.com</a
        >.
      </p>

      <section>
        <ul>
          {
            posts.map((post) => (
              <li>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>

                <h3 class="title">{post.data.titre_francais}</h3>

                <p class="description">{post.data.description_francais}</p>
                <p class="link">
                  <a href={post.data.link} target="_blank">
                    {post.data.link}
                  </a>
                </p>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
